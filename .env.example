# Required: Anthropic API key for the primary reviewer
ANTHROPIC_API_KEY=sk-ant-...

# Optional: OpenAI API key for the comparison model in evals
OPENAI_API_KEY=sk-...

# Optional: GitHub token for fetching PRs. Without this, only public PRs work
# and you'll hit the unauthenticated rate limit (60 req/hour).
GITHUB_TOKEN=ghp_...

# Optional: override defaults
# SECREVIEW_PRIMARY_MODEL=claude-sonnet-4-6
# SECREVIEW_COMPARISON_MODEL=gpt-4o